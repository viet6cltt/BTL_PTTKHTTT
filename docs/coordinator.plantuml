@startuml
title Flow: Coordinator creates and finalizes facility contract

autonumber

actor "Coordinator\n(EMPLOYEE)" as Coordinator
boundary "Contract UI" as UI
control "Seminar Management System" as System
database "Database" as DB
collections "File Storage" as Storage

Coordinator -> UI : Select seminar and facility
UI -> System : createContract(seminar_id, facility_id, employee_id)

System -> DB : Check SEMINAR exists
DB --> System : seminar data

System -> DB : Check FACILITY exists
DB --> System : facility data

System -> DB : Check coordinator EMPLOYEE exists
DB --> System : employee data

System -> DB : Check seminar has no existing contract
DB --> System : no contract found

System -> DB : Insert SEMINAR_FACILITY_CONTRACT\nseminar_id, facility_id,\nreservation_date,\nstatus = "NOTSIGNED",\ncontract_created_date = NULL,\ntotal_cost = NULL
DB --> System : contract_id

System --> UI : Show draft contract
UI --> Coordinator : Draft contract created

Coordinator -> UI : Enter room reservation information

loop For each reserved room
    UI -> System : addRoomReservation(contract_id,\nnum_seats, start_time, end_time,\nroom_width, room_length,\nseat_arrangement_notes, room_cost)

    System -> DB : Check SEMINAR_FACILITY_CONTRACT exists
    DB --> System : contract data

    System -> System : Validate room reservation\nstart_time < end_time\nroom_cost >= 0

    alt Invalid room information
        System --> UI : Show room validation errors
        UI --> Coordinator : Ask coordinator to correct room data
    else Valid room information
        System -> DB : Insert FACILITY_ROOM_RESERVATION
        DB --> System : room_id
        System --> UI : Room reservation saved
    end
end

Coordinator -> UI : Enter AV equipment rental information

loop For each AV equipment
    UI -> System : addAVEquipmentReservation(contract_id,\nequipment_id, quantity_reserved,\ncost_for_each_equipment)

    System -> DB : Check SEMINAR_FACILITY_CONTRACT exists
    DB --> System : contract data

    System -> DB : Check AUDIO_VISUAL_EQUIPMENT exists
    DB --> System : equipment data

    System -> System : Validate AV reservation\nquantity_reserved > 0\ncost_for_each_equipment >= 0

    alt Invalid AV information
        System --> UI : Show AV validation errors
        UI --> Coordinator : Ask coordinator to correct AV data
    else Valid AV information
        System -> DB : Insert AV_EQUIPMENT_RESERVATION
        DB --> System : AV reservation saved
        System --> UI : AV reservation saved
    end
end

Coordinator -> UI : Upload signed contract document
UI -> System : finalizeContract(contract_id, file)

System -> DB : Check SEMINAR_FACILITY_CONTRACT exists
DB --> System : contract status = "NOTSIGNED"

System -> DB : Check contract has no CONTRACT_DOCUMENT
DB --> System : no document found

System -> System : Validate uploaded file\nfile is not empty\nfile_type is allowed

alt Invalid contract file
    System --> UI : Show upload error
    UI --> Coordinator : Ask coordinator to upload valid file
else Valid contract file
    System -> Storage : Save uploaded contract file
    Storage --> System : file_url

    System -> DB : Insert CONTRACT_DOCUMENT\ncontract_id, file_name, file_type,\nfile_url, uploaded_at, notes
    DB --> System : document_id

    System -> DB : Calculate total cost\nfrom room_cost and AV cost
    DB --> System : total_cost

    System -> DB : Update SEMINAR_FACILITY_CONTRACT\nstatus = "SIGNED",\ncontract_created_date = current_date,\ntotal_cost = calculated_total_cost
    DB --> System : contract finalized

    System --> UI : Show finalized contract
    UI --> Coordinator : Contract finalized successfully
end

@enduml